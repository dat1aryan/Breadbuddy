# Server configuration
# Use BREADBUDDY_PORT to avoid conflicts with other apps that set PORT
BREADBUDDY_PORT=4000
CORS_ORIGIN=http://localhost:5173

# JWT secret - change this to a long random string in production
JWT_SECRET=change-this-to-a-super-secret-random-string-bestie

# Optional: custom database path
# DATABASE_PATH=./data/breadbuddy.db
